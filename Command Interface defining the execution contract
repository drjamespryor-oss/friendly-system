// Command Interface defining the execution contract
interface MarketOrderCommand {
  readonly id: string;
  execute(): Promise<void>;
  rollback(): Promise<void>;
}

interface PortfolioState {
  cash: number;
  positions: Map<string, number>;
}

// Concrete Command handling asset purchase tasks
class BuyOrderCommand implements MarketOrderCommand {
  public readonly id: string;

  constructor(
    private state: PortfolioState,
    private ticker: string,
    private shares: number,
    private executionPrice: number
  ) {
    this.id = `BUY_${ticker}_${Math.random().toString(36).substring(2, 7).toUpperCase()}`;
  }

  public async execute(): Promise<void> {
    const totalCost = this.shares * this.executionPrice;
    if (totalCost > this.state.cash) {
      throw new Error(`Execution Denied [${this.id}]: Liquidity constraints breached.`);
    }
    
    this.state.cash -= totalCost;
    const currentShares = this.state.positions.get(this.ticker) || 0;
    this.state.positions.set(this.ticker, currentShares + this.shares);
  }

  public async rollback(): Promise<void> {
    const totalRefund = this.shares * this.executionPrice;
    this.state.cash += totalRefund;
    const currentShares = this.state.positions.get(this.ticker) || 0;
    
    if (currentShares <= this.shares) {
      this.state.positions.delete(this.ticker);
    } else {
      this.state.positions.set(this.ticker, currentShares - this.shares);
    }
  }
}

// Concrete Command handling asset liquidation tasks
class SellOrderCommand implements MarketOrderCommand {
  public readonly id: string;

  constructor(
    private state: PortfolioState,
    private ticker: string,
    private shares: number,
    private executionPrice: number
  ) {
    this.id = `SELL_${ticker}_${Math.random().toString(36).substring(2, 7).toUpperCase()}`;
  }

  public async execute(): Promise<void> {
    const currentShares = this.state.positions.get(this.ticker) || 0;
    if (currentShares < this.shares) {
      throw new Error(`Execution Denied [${this.id}]: Asset volume deficit.`);
    }

    const totalRevenue = this.shares * this.executionPrice;
    this.state.cash += totalRevenue;

    if (currentShares === this.shares) {
      this.state.positions.delete(this.ticker);
    } else {
      this.state.positions.set(this.ticker, currentShares - this.shares);
    }
  }

  public async rollback(): Promise<void> {
    const currentShares = this.state.positions.get(this.ticker) || 0;
    this.state.positions.set(this.ticker, currentShares + this.shares);
    this.state.cash -= (this.shares * this.executionPrice);
  }
}

// Invoker Class executing and managing trade transaction buffers
class TradeExecutionInvoker {
  private commandQueue: MarketOrderCommand[] = [];
  private executionHistory: MarketOrderCommand[] = [];

  public stageOrder(order: MarketOrderCommand): void {
    this.commandQueue.push(order);
  }

  // Processes sequential transactions while timing total performance footprint
  public async processPipelineQueue(): Promise<{ durationMs: number; processedCount: number }> {
    const startTime = performance.now();
    const processedCount = this.commandQueue.length;

    while (this.commandQueue.length > 0) {
      const command = this.commandQueue.shift();
      if (!command) break;

      try {
        await command.execute();
        this.executionHistory.push(command);
      } catch (error: any) {
        console.error(`🛑 Critical Processing Error: ${error.message}. Initiating rollback chain...`);
        await this.rollbackExecutedChain();
        break;
      }
    }

    const endTime = performance.now();
    return {
      durationMs: parseFloat((endTime - startTime).toFixed(4)),
      processedCount
    };
  }

  private async rollbackExecutedChain(): Promise<void> {
    while (this.executionHistory.length > 0) {
      const command = this.executionHistory.pop();
      if (command) {
        console.log(` -> Reverting Transaction Reference: [${command.id}]`);
        await command.rollback();
      }
    }
  }
}

