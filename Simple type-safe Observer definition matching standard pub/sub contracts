// Simple type-safe Observer definition matching standard pub/sub contracts
type ObserverCallback<T> = (data: T) => void;

// 1. Reactive Broadcast Hub (Event Emitter Subsystem)
class PortfolioEventEmitter<T> {
  private listeners: Map<string, ObserverCallback<T>[]> = new Map();

  public subscribe(event: string, callback: ObserverCallback<T>): void {
    if (!this.listeners.has(event)) {
      this.listeners.set(event, []);
    }
    this.listeners.get(event)!.push(callback);
  }

  public emit(event: string, data: T): void {
    const eventListeners = this.listeners.get(event);
    if (eventListeners) {
      eventListeners.forEach(callback => callback(data));
    }
  }
}

// 2. Structural Layout Shapes for the Immutable Matrix
interface HoldingEntity {
  readonly ticker: string;
  readonly volume: number;
  readonly valuation: number;
}

interface FinancialState {
  readonly liquidCash: number;
  readonly equityPositions: readonly HoldingEntity[];
  readonly totalNetValue: number;
}

// 3. Main Immutable State Management Container
class DeepFrozenStateStore {
  private currentState: FinancialState;
  private eventHub: PortfolioEventEmitter<FinancialState>;

  constructor(initialState: FinancialState, emitter: PortfolioEventEmitter<FinancialState>) {
    this.currentState = this.deepFreeze(initialState);
    this.eventHub = emitter;
  }

  // Enforces complete structural immutability at compile and runtime
  private deepFreeze<U extends object>(obj: U): U {
    Object.freeze(obj);
    Object.getOwnPropertyNames(obj).forEach(prop => {
      const value = (obj as any)[prop];
      if (value !== null && typeof value === "object" && !Object.isFrozen(value)) {
        this.deepFreeze(value);
      }
    });
    return obj;
  }

  public getState(): FinancialState {
    return this.currentState;
  }

  /**
   * State Mutation Hub: Generates a completely new frozen state snapshot using 
   * predictable functional updates, then broadcasts it to streaming observers.
   */
  public dispatchTransition(action: (state: FinancialState) => FinancialState, eventContext: string): void {
    const nextUnfrozenState = action(this.currentState);
    this.currentState = this.deepFreeze(nextUnfrozenState);
    this.eventHub.emit(eventContext, this.currentState);
  }
}

